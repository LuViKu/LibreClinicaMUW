target/
# Phase D-Sec audit (2026-05-30): `odm/src/main/java/` removed — the
# JAXB-generated XML-binding classes under that directory are now
# committed per the documented Phase B.4 intent ("The generated
# sources under src/main/java/ are committed to the repo" — see
# the jaxb2-maven-plugin comment in odm/pom.xml). Previously the
# gitignore was excluding them while xjc was disabled in the build,
# leaving CI unable to compile web/ (which imports the generated
# org.cdisc.ns.odm.* + org.openclinica.ns.* packages). 513 files
# checked in once; re-enable xjc when jaxb2-maven-plugin gains
# jakarta-XJC support for the multi-schema ODM tree, then re-add
# this gitignore entry.
odm/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
.classpath
.project
.settings/
.idea/
LibreClinica.iml
OpenClinica.iml
web/src/main/resources/datainfo.properties
core/*.iml
odm/*.iml
docs/*.iml
web/*.iml
ws/*.iml
.DS_Store
core/.DS_Store
web/.DS_Store
ws/.DS_Store

# git
*.orig

# netbeans
nb-configuration.xml
/.README.md.html
.m2-cache/
.m2-cache-it/

# Test-run pollution: tests evaluate `filePath=${catalina.home}/...` outside Tomcat,
# leaving a literal-named directory. See core/src/test/resources/datainfo.properties.
catalina.home_IS_UNDEFINED/
**/catalina.home_IS_UNDEFINED/
