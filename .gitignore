# Test-run pollution: tests evaluate `filePath=${catalina.home}/...` outside Tomcat,
# leaving a literal-named directory. See core/src/test/resources/datainfo.properties.
catalina.home_IS_UNDEFINED/
**/catalina.home_IS_UNDEFINED/

# Phase E SPA build output (Vite outDir per web/src/spa/vite.config.ts).
# Generated by `pnpm build` or `mvn package` (frontend-maven-plugin);
# packaged into the WAR by maven-war-plugin at build time.
web/src/main/webapp/app/

# pnpm store left behind by the docker-based vitest runner used in the
# autonomous SPA-test workflow (`pnpm exec vitest run …` inside the
# node:20-alpine container falls back to creating .pnpm-store at the
# bind-mount root when the container can't write to its default cache).
.pnpm-store/
