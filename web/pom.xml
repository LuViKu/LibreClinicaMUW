 		</dependency>
		<dependency>
			<groupId>jakarta.mail</groupId>
			<artifactId>jakarta.mail-api</artifactId>
		</dependency>
		<dependency>
			<groupId>jakarta.xml.bind</groupId>
			<artifactId>jakarta.xml.bind-api</artifactId>
		</dependency>
		<!-- Phase B.4 cliff: taglibs:standard 1.1 (Sun JSTL 1.1 RI, javax-only)
		     removed. Replaced by jakarta.servlet.jsp.jstl-api 3.0 +
		     org.glassfish.web:jakarta.servlet.jsp.jstl 3.x impl already
