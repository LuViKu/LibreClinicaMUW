			     legacy servlets registered at exact URL patterns via
			     LegacyServletRegistry — exact-match precedence wins). Only
			     health + info are exposed by default; expand via
			     management.endpoints.web.exposure.include in application.yml. -->
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-actuator</artifactId>
