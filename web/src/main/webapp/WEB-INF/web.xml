<?xml version="1.0" encoding="ISO-8859-1"?>
<web-app version="2.4"
         xmlns="http://java.sun.com/xml/ns/j2ee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
    <display-name>LibreClinica</display-name>
    <description>LibreClinica Web Interface</description>

    <!--
        Phase C.14 cliff (2026-05-30): contextConfigLocation, all listeners,
        and all filters migrated out of web.xml. Boot's
        SpringBootServletInitializer owns root-context bootstrap;
        ServletInfraConfig owns surviving listeners + non-security filters;
        SecurityConfig owns the SecurityFilterChain @Bean. The 222 servlet
        declarations stay here for now — Boot does NOT auto-register Servlet
        beans, so they don't collide. Bulk servlet migration to
        LegacyServletRegistry @Configuration is a post-cliff cleanup pass
        (see phase-c14-web-xml-inventory.md).
    -->

    <context-param>
        <param-name>jmesaMessagesLocation</param-name>
        <param-value>at/ac/meduniwien/ophthalmology/libreclinica/jmesaResourceBundle</param-value>
    </context-param>

    <context-param>
        <param-name>SQLInitServlet</param-name>
        <param-value>org/</param-value>
    </context-param>


    <servlet>
        <servlet-name>pages</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>
        <load-on-startup>2</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>pages</servlet-name>
        <url-pattern>/pages/*</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>pages</servlet-name>
        <url-pattern>/oauth/*</url-pattern>
    </servlet-mapping>

    <!-- Phase C.16 (2026-05-30): 221 legacy servlet declarations migrated to
         config.LegacyServletRegistry (Boot @Configuration). Only the `pages`
         DispatcherServlet stays here because it loads its child context via
         the default `/WEB-INF/pages-servlet.xml` lookup path (which now
         contains a stub `<bean class="WebMvcConfig"/>`). The `ws` Spring-WS
         MessageDispatcherServlet + 2 Jersey servlets dropped here are the
         zombies inventoried in phase-c14-web-xml-inventory.md — Tomcat
         marked them unavailable on every deploy via
         java.lang.ClassNotFoundException: javax.servlet.Filter against
         the spring-ws / com.sun.jersey jars that never made the jakarta
         transition. -->

</web-app>
