{
  "name": "libreclinica-muw-spa",
  "version": "0.0.1",
  "description": "Phase E SPA front-end for LibreClinica MUW \u2014 Vue 3 + Vite + Tailwind v4. Bundled into the WAR at /LibreClinica/app/ via the Frontend Maven Plugin (see web/pom.xml).",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run src/test/a11y",
    "test:e2e": "playwright test",
    "test:a11y:e2e": "playwright test --grep @a11y",
    "stories": "histoire dev",
    "stories:build": "histoire build",
    "lint": "eslint --ext .vue,.ts src",
    "format": "prettier --write src",
    "check-tokens": "node scripts/check-tokens.mjs",
    "check-i18n": "node scripts/check-i18n-coverage.mjs",
    "codegen:openapi": "openapi-typescript http://127.0.0.1:8080/LibreClinica/v3/api-docs/spa-api -o src/types/api.ts"
  },
  "dependencies": {
    "pinia": "^2.2.2",
    "vue": "^3.4.38",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.4.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@histoire/plugin-vue": "^0.17.17",
    "@playwright/test": "^1.47.0",
    "@tailwindcss/vite": "^4.0.0-beta.1",
    "@types/node": "^22.5.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "@vue/test-utils": "^2.4.6",
    "axe-core": "^4.10.0",
    "eslint": "^9.9.1",
    "eslint-plugin-vue": "^9.27.0",
    "histoire": "^0.17.17",
    "jsdom": "^25.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.0.0-beta.1",
    "typescript": "~5.5.4",
    "vite": "^5.4.3",
    "vitest": "^2.0.5",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^2.1.4"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.10.0"
}
