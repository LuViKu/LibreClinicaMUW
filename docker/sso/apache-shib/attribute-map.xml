<?xml version="1.0" encoding="UTF-8"?>
<!--
    LibreClinica MUW Ophthalmology — Shibboleth SP attribute map

    Phase D.7 (DR-014): maps SAML attributes from the IdP response
    to HTTP request headers that LibreClinica's
    RequestHeaderAuthenticationFilter consumes (see D.3
    SsoProperties.header.*).

    The default header names match LibreClinica's defaults:
    - eppn (eduPersonPrincipalName) → REMOTE_USER (the principal)
    - mail → mail (the email attribute)
    - displayName → displayName

    Production may add institutional attributes (e.g.
    eduPersonAffiliation, eduPersonScopedAffiliation) for
    DR-017 role-mapping rules.
-->
<Attributes xmlns="urn:mace:shibboleth:2.0:attribute-map"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <!-- eduPersonPrincipalName — the canonical SSO username.
         shibboleth2.xml maps this to REMOTE_USER via the
         ApplicationDefaults REMOTE_USER attribute-order list. -->
    <Attribute name="urn:oid:1.3.6.1.4.1.5923.1.1.1.6" id="eppn">
        <AttributeDecoder xsi:type="ScopedAttributeDecoder"/>
    </Attribute>
    <Attribute name="urn:mace:dir:attribute-def:eduPersonPrincipalName" id="eppn">
        <AttributeDecoder xsi:type="ScopedAttributeDecoder"/>
    </Attribute>

    <!-- mail — RFC822 email address. -->
    <Attribute name="urn:oid:0.9.2342.19200300.100.1.3" id="mail"/>
    <Attribute name="urn:mace:dir:attribute-def:mail" id="mail"/>

    <!-- displayName — human-friendly name for greeting screens. -->
    <Attribute name="urn:oid:2.16.840.1.113730.3.1.241" id="displayName"/>
    <Attribute name="urn:mace:dir:attribute-def:displayName" id="displayName"/>

    <!-- cn (common name) — fallback for displayName. -->
    <Attribute name="urn:oid:2.5.4.3" id="cn"/>
    <Attribute name="urn:mace:dir:attribute-def:cn" id="cn"/>

    <!-- givenName + sn — for greeting + admin views. -->
    <Attribute name="urn:oid:2.5.4.42" id="givenName"/>
    <Attribute name="urn:oid:2.5.4.4" id="sn"/>

    <!-- eduPersonAffiliation — DR-017 role-mapping input
         (member / staff / student / faculty / employee). -->
    <Attribute name="urn:oid:1.3.6.1.4.1.5923.1.1.1.1" id="affiliation">
        <AttributeDecoder xsi:type="ScopedAttributeDecoder" caseSensitive="false"/>
    </Attribute>

    <!-- eduPersonScopedAffiliation — DR-017 role-mapping input
         scoped by realm (e.g. staff@meduniwien.ac.at). -->
    <Attribute name="urn:oid:1.3.6.1.4.1.5923.1.1.1.9" id="affiliation">
        <AttributeDecoder xsi:type="ScopedAttributeDecoder" caseSensitive="false"/>
    </Attribute>

    <!-- Persistent SAML name identifier — when eppn is unavailable. -->
    <Attribute name="urn:oasis:names:tc:SAML:2.0:nameid-format:persistent" id="persistent-id">
        <AttributeDecoder xsi:type="NameIDAttributeDecoder" formatter="$NameQualifier!$SPNameQualifier!$Name" defaultQualifiers="true"/>
    </Attribute>

</Attributes>
