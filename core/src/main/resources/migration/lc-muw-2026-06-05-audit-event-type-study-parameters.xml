<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <!--
        Phase E.6 study-params (2026-06-05): audit_log_event_type row
        for study-parameter edits emitted by
        StudyParametersApiController PUT.

        Sibling of id 51 ("study_identity_updated") added 2026-06-03,
        and 50 ("user_account profile updated") added 2026-06-03.
        52 + 53 are dataset-export / subject-export (Phase E.6 export
        cluster). Allocates id 54 so the Audit Log view's
        variantForType in AuditApiController can route it into the
        "admin" bucket (same as 51).

        Without this seed the controller's per-handle INSERT into
        audit_log_event still works (audit_log_event has no FK to
        audit_log_event_type), but the row would surface in the SPA
        Audit Trail view without a localised label and would fall
        through to the "other" filter. Keeping the seed reproducible
        via Liquibase mirrors the user_profile + study_identity
        precedent rather than relying on a hot-fix INSERT.
    -->
    <changeSet id="2026-06-05-audit-event-type-study-parameters"
               author="muw-ophthalmology"
               dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM audit_log_event_type
                WHERE audit_log_event_type_id = 54;
            </sqlCheck>
        </preConditions>
        <comment>
            Seed the row the StudyParametersApiController emits via
            the per-handle INSERT in audit_log_event.
        </comment>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="54"/>
            <column name="name" value="study_parameters_updated"/>
            <column name="display_name" value="Study parameters updated"/>
        </insert>
    </changeSet>

</databaseChangeLog>
