<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <!--
        Phase E.6 (2026-06-03 evening): Spring Security authority rows
        for the seeded demo users (physician, monitor, datamanager).

        The Phase E.5 seed at lc-muw-2026-06-02-seed-demo-test-users.xml
        inserted the user_account + study_user_role rows for each user
        but skipped the `authorities` table — only root had an
        authorities row, carried over from the legacy bootstrap. Spring
        Security's JdbcUserDetailsManager requires BOTH a user_account
        AND a matching authorities row to authenticate; without the
        latter, j_spring_security_check redirected to
        /pages/login/login?action=errorLogin (the SPA renders this as
        "Invalid username or password" — see auth.ts:localLogin).

        Reported 2026-06-03: datamanager could not log in. The same
        bug affected physician and monitor — those went undiagnosed
        because the operator hadn't tried them yet.

        idempotent: only insert when no row exists for the username.
    -->
    <changeSet id="2026-06-03-seed-authority-physician"
               author="muw-ophthalmology"
               context="demo">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM authorities WHERE username = 'physician';
            </sqlCheck>
        </preConditions>
        <insert tableName="authorities">
            <column name="username" value="physician"/>
            <column name="authority" value="ROLE_USER"/>
            <column name="version" valueNumeric="1"/>
        </insert>
    </changeSet>

    <changeSet id="2026-06-03-seed-authority-monitor"
               author="muw-ophthalmology"
               context="demo">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM authorities WHERE username = 'monitor';
            </sqlCheck>
        </preConditions>
        <insert tableName="authorities">
            <column name="username" value="monitor"/>
            <column name="authority" value="ROLE_USER"/>
            <column name="version" valueNumeric="1"/>
        </insert>
    </changeSet>

    <changeSet id="2026-06-03-seed-authority-datamanager"
               author="muw-ophthalmology"
               context="demo">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM authorities WHERE username = 'datamanager';
            </sqlCheck>
        </preConditions>
        <insert tableName="authorities">
            <column name="username" value="datamanager"/>
            <column name="authority" value="ROLE_USER"/>
            <column name="version" valueNumeric="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>
