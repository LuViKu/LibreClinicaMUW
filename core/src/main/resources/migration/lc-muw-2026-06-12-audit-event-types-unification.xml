            <column name="display_name" value="Rules import committed"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="89"/>
            <column name="name" value="rule_set_rule_lifecycle_changed"/>
            <column name="display_name" value="Rule set rule lifecycle changed"/>
        </insert>

        <!-- Site + Study (SitesApiController, StudiesApiController) -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="90"/>
            <column name="name" value="site_lifecycle_changed"/>
            <column name="display_name" value="Site lifecycle changed"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="91"/>
            <column name="name" value="site_field_updated"/>
            <column name="display_name" value="Site field updated"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="92"/>
            <column name="name" value="study_lifecycle_changed"/>
            <column name="display_name" value="Study lifecycle changed"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="93"/>
            <column name="name" value="study_status_changed"/>
            <column name="display_name" value="Study status changed"/>
        </insert>

        <!-- Study event (EventsApiController) -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="94"/>
            <column name="name" value="study_event_updated"/>
            <column name="display_name" value="Study event updated"/>
        </insert>

        <!-- Event definitions (EventDefinitionsApiController) -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="95"/>
            <column name="name" value="event_definition_lifecycle_changed"/>
            <column name="display_name" value="Event definition lifecycle changed"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="96"/>
            <column name="name" value="event_definition_disabled"/>
            <column name="display_name" value="Event definition disabled"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="97"/>
            <column name="name" value="event_definition_field_updated"/>
            <column name="display_name" value="Event definition field updated"/>
        </insert>

        <!-- Group classes (GroupClassesApiController) -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="98"/>
            <column name="name" value="group_class_lifecycle_changed"/>
            <column name="display_name" value="Group class lifecycle changed"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="99"/>
            <column name="name" value="group_class_field_updated"/>
            <column name="display_name" value="Group class field updated"/>
        </insert>

        <!-- Subject demographics (SubjectsApiController) -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="100"/>
