        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="84"/>
            <column name="name" value="rule_action_updated"/>
            <column name="display_name" value="Rule action updated"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="85"/>
            <column name="name" value="rule_set_created"/>
            <column name="display_name" value="Rule set created"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="86"/>
            <column name="name" value="rule_set_lifecycle_changed"/>
            <column name="display_name" value="Rule set lifecycle changed"/>
        </insert>
        <insert tableName="audit_log_event_type">
