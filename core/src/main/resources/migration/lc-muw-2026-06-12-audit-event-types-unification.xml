        </insert>

        <!-- User account + login (UsersApiController, login servlets, legacy helpers) -->
        <!-- Type 101 hidden (is_user_visible=false) — failed-login rows
             belong in the sysadmin /api/v1/audit/system view, not the
             per-study investigator audit trail. Matches type-61/62 pattern. -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="101"/>
            <column name="name" value="user_login_failed"/>
            <column name="display_name" value="User login failed"/>
            <column name="is_user_visible" valueBoolean="false"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="102"/>
            <column name="name" value="user_logged_in"/>
            <column name="display_name" value="User logged in"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="103"/>
            <column name="name" value="user_password_request_legacy"/>
            <column name="display_name" value="User password request (legacy path)"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="104"/>
            <column name="name" value="user_account_admin_action"/>
            <column name="display_name" value="User account — admin action"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="105"/>
            <column name="name" value="user_account_generic"/>
            <column name="display_name" value="User account — generic"/>
        </insert>

        <!-- Background-job execution (XsltTransformJob + siblings) -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="106"/>
            <column name="name" value="extract_job_succeeded"/>
            <column name="display_name" value="Extract job succeeded"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="107"/>
            <column name="name" value="extract_job_failed"/>
            <column name="display_name" value="Extract job failed"/>
        </insert>

        <!-- Backfill catch-all for ~80 historical action_message keys
             that don't map cleanly to a typed id. Hidden from per-study
             views; sysadmin can run a compliance report off this bucket
             to escalate individual rows if needed. -->
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="108"/>
            <column name="name" value="legacy_unmapped"/>
            <column name="display_name" value="Legacy audit_event row (unmapped)"/>
            <column name="is_user_visible" valueBoolean="false"/>
        </insert>

        <rollback>
            <delete tableName="audit_log_event_type">
                <where>audit_log_event_type_id BETWEEN 75 AND 108</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
