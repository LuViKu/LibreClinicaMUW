            <column name="display_name" value="Rule created"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="82"/>
            <column name="name" value="rule_updated"/>
            <column name="display_name" value="Rule updated"/>
        </insert>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="83"/>
