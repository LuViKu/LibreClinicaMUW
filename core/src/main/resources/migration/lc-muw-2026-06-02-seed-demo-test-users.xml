    <!--
        Phase E.6 (2026-06-03): collapse any pre-existing duplicate
        active binding for root on the Default Study. Whatever the
        historical sequence (an early Monitor seed plus a later
        SPA-driven admin update could both leave active rows since
        study_user_role has no primary key + the table-level UPDATE
        in updateRole only mutates one binding at a time), this
        idempotent UPDATE deactivates every-but-one of root's active
        rows on study_id=1.

        Implementation uses PostgreSQL's ctid system column as a
        stable per-row identifier — study_user_role intentionally has
        no surrogate key, so ctid is the only thing that distinguishes
        otherwise-identical rows. We keep one row arbitrarily (MIN
        ctid) and mark the rest status_id=7 (AUTO-DELETED). Runs only
        when more than one active root binding actually exists, which
        is precisely the duplicate-in-SPA-user-list condition.
    -->
    <changeSet id="2026-06-03-dedupe-root-active-bindings"
               author="muw-ophthalmology"
               context="demo"
               dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="t">
                SELECT (COUNT(*) > 1)::text FROM study_user_role
                WHERE user_name = 'root' AND study_id = 1 AND status_id = 1;
            </sqlCheck>
        </preConditions>
        <comment>
            Deactivate root's surplus active bindings so a single row
            survives. Backend already dedupes at read time (PR #101);
            this also cleans up the underlying data so subsequent
            updateRole calls hit one row deterministically.
        </comment>
        <sql>
            UPDATE study_user_role
               SET status_id = 7
             WHERE user_name = 'root'
               AND study_id  = 1
               AND status_id = 1
               AND ctid &lt;&gt; (
                   SELECT MIN(ctid) FROM study_user_role
                    WHERE user_name = 'root'
                      AND study_id  = 1
                      AND status_id = 1
               );
        </sql>
    </changeSet>

</databaseChangeLog>
