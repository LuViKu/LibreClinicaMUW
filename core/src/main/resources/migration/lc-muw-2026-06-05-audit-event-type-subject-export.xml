<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <!--
        Phase E.6 Data Export Phase 5 (2026-06-05): audit_log_event_type
        row for one-click per-subject data exports emitted by
        SubjectExportApiController.POST /api/v1/studies/{studyOid}/subjects/{label}/export.

        Why a dedicated type. The "Download my data" surface is a
        one-click snapshot — distinct from the legacy create-dataset →
        download flow (which has its own audit hooks) and distinct from
        the audit-log-export type Phase 6 may seed. A dedicated row
        means the Audit Trail SPA renders it under a recognisable
        label without piggy-backing on a heterogeneous "export" bucket.

        ID allocation. 50 + 51 are taken by Phase E.5/E.6
        (lc-muw-2026-06-03-audit-event-type-user-profile.xml,
         lc-muw-2026-06-03-audit-event-type-study-identity.xml).
        We pick 53 leaving 52 free for Phase 6 audit-log-export (per
        the cross-PR coordination note in the brief). The preCondition
        guards against a future double-seed in case Phase 6 races us
        and lands first claiming 53 — Liquibase MARK_RAN means we
        skip cleanly without failing the bootstrap.
    -->
    <changeSet id="2026-06-05-audit-event-type-subject-export"
               author="muw-ophthalmology"
               dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM audit_log_event_type
                WHERE audit_log_event_type_id = 53;
            </sqlCheck>
        </preConditions>
        <comment>
            Seed the audit_log_event_type row the SubjectExportApiController
            writes whenever a subject snapshot (ODM/CSV/PDF) is streamed
            to the operator.
        </comment>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="53"/>
            <column name="name" value="subject_data_exported"/>
            <column name="display_name" value="Subject data exported"/>
        </insert>
    </changeSet>

</databaseChangeLog>
