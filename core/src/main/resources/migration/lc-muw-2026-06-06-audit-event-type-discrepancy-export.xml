<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

    <!--
        Phase E.6 (2026-06-06): audit_log_event_type row for the
        new /api/v1/discrepancies/export.csv endpoint.
        DiscrepancyApiController emits one row per successful CSV
        export so the GxP audit trail records who downloaded the
        discrepancy list + which filter set was active.

        Allocates id 55 next to id 54 (audit log export). Maps
        into the "admin" variant bucket via
        AuditApiController.variantForType so the new rows surface
        under the SPA's existing Admin filter.

        Why a new type vs. piggy-backing on 54:
        Discrepancy exports leave the system boundary with PHI-
        adjacent metadata (subject labels, item OIDs, query
        descriptions). Sponsors / inspectors review this stream
        independently of the audit-trail-export stream.
    -->
    <changeSet id="2026-06-06-audit-event-type-discrepancy-export"
               author="muw-ophthalmology"
               dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM audit_log_event_type
                WHERE audit_log_event_type_id = 56;
            </sqlCheck>
        </preConditions>
        <comment>
            Seed the row DiscrepancyApiController.emitExportAudit
            emits via direct INSERT into audit_log_event when the
            /api/v1/discrepancies/export.csv endpoint serves a
            download.
        </comment>
        <insert tableName="audit_log_event_type">
            <column name="audit_log_event_type_id" valueNumeric="56"/>
            <column name="name" value="discrepancy_log_exported"/>
            <column name="display_name" value="Discrepancy log exported"/>
        </insert>
    </changeSet>

</databaseChangeLog>
