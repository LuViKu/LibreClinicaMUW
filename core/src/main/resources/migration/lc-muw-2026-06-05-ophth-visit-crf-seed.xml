            <column name="name" value="Ophthalmology Visit"/>
            <column name="description" value="Per-visit eye examination: visual acuity, intraocular pressure, manifest refraction, lens status. Per-eye items use OD (right) / OS (left); both eyes recorded each visit unless the study-eye scope excludes one."/>
            <column name="owner_id" valueNumeric="1"/>
            <column name="date_created" valueDate="2026-06-05"/>
            <column name="oc_oid" value="F_OPHTH_VISIT"/>
        </insert>
        <insert tableName="crf_version">
            <column name="crf_version_id" valueNumeric="2"/>
            <column name="crf_id" valueNumeric="2"/>
            <column name="name" value="v1.0"/>
            <column name="description" value="Initial Ophthalmology Visit version — MUW Department of Ophthalmology &amp; Optometry standard."/>
            <column name="status_id" valueNumeric="1"/>
            <column name="date_created" valueDate="2026-06-05"/>
            <column name="owner_id" valueNumeric="1"/>
            <column name="oc_oid" value="F_OPHTH_VISIT_V1"/>
        </insert>

        <!-- ============================================================
             Sections
             ============================================================ -->
