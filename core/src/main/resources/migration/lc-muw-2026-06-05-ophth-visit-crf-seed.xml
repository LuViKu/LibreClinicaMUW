            <column name="instructions" value="Best-corrected distance visual acuity. Capture both LogMAR (decimal) and ETDRS letter score (0-100) per eye. If only one method was used, leave the other blank — the export pipeline handles missing values."/>
            <column name="ordinal" valueNumeric="1"/>
            <column name="date_created" valueDate="2026-06-05"/>
            <column name="owner_id" valueNumeric="1"/>
        </insert>
        <insert tableName="section">
            <column name="section_id" valueNumeric="4"/>
