             NLP=no light perception, NR=not recordable. Same coding
             convention as ETDRS protocol acuity charts. -->
        <insert tableName="response_set">
            <column name="response_set_id" valueNumeric="4"/>
            <column name="response_type_id" valueNumeric="6"/> <!-- single-select -->
            <column name="label" value="snellen_20ft"/>
            <column name="options_text" value="20/16,20/20,20/25,20/32,20/40,20/50,20/63,20/80,20/100,20/125,20/160,20/200,20/250,20/320,20/400,CF,HM,LP,NLP,NR"/>
            <column name="options_values" value="20/16,20/20,20/25,20/32,20/40,20/50,20/63,20/80,20/100,20/125,20/160,20/200,20/250,20/320,20/400,CF,HM,LP,NLP,NR"/>
            <column name="version_id" valueNumeric="2"/>
        </insert>

        <!-- rs_id=5 IOP units — single value, but the dropdown
             documents the unit explicitly so a downstream consumer
