<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
                           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--
        Phase C.3-finish (2026-05-30): dataSource + queryStore are now defined
        in at.ac.meduniwien.ophthalmology.libreclinica.config.DataSourceConfig.

        liquibase stays here until C.13 retires it in favour of
        spring-boot-starter-liquibase autoconfig. Defining the SpringLiquibase
        bean from Java would require flipping liquibase-core's dependency
        scope from runtime → compile in core/pom.xml; C.13's autoconfig
        approach eliminates the SpringLiquibase reference entirely instead,
        so we punt on the scope bump.
    -->
    <bean class="at.ac.meduniwien.ophthalmology.libreclinica.config.DataSourceConfig"/>

    <bean id="liquibase" class="liquibase.integration.spring.SpringLiquibase" depends-on="coreResources">
        <property name="dataSource" ref="dataSource"/>
        <property name="changeLog" value="classpath:migration/master.xml"/>
    </bean>

</beans>
