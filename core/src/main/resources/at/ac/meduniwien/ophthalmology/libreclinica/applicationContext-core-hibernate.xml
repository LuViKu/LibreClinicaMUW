                <prop key="hibernate.show_sql">false</prop>
                <prop key="hibernate.format_sql">true</prop>
                <prop key="hibernate.dialect">s[hibernate.dialect]</prop>
                <prop key="hibernate.generate_statistics">true</prop>
                <!-- Phase B.4 cliff: 2L cache temporarily disabled.
                     hibernate-ehcache 5.x is javax-only with no jakarta-namespaced
                     sibling at 5.6.x; the WIP commit dropped the dependency from
                     core/pom.xml in preparation for B.5 (Hibernate 6.4 + jcache +
                     ehcache 3). Re-enable in B.5 with:
                       org.hibernate.cache.jcache.JCacheRegionFactory
                       + ehcache 3.x JSR-107 provider. -->
                <prop key="hibernate.cache.use_query_cache">false</prop>
                <prop key="hibernate.cache.use_second_level_cache">false</prop>
                <prop key="hibernate.allow_update_outside_transaction">true</prop>
                <!-- Phase B.5: switched from <property name="implicitNamingStrategy">
                     to the property-based form. Spring 6's hibernate5
                     LocalSessionFactoryBuilder.setImplicitNamingStrategy was
                     compiled against Hibernate 5's void-returning method;
                     Hibernate 6 changed it to a builder-style return type and
                     triggers a NoSuchMethodError. The
                     hibernate.implicit_naming_strategy hibernate-property
                     path is stable across both versions and accepts the
                     fully-qualified class name. -->
                <prop key="hibernate.implicit_naming_strategy">at.ac.meduniwien.ophthalmology.libreclinica.dao.hibernate.cfg.LegacyImprovedImplicitNamingStrategy</prop>
                <!-- Phase B.5: Hibernate 6 enforces that @SequenceGenerator's
                     allocationSize matches the DB sequence's actual INCREMENT BY.
                     The LibreClinica schema uses INCREMENT BY 1 sequences but
                     the entities default to allocationSize=50. Switch the
                     strategy from the default EXCEPTION to LOG so Hibernate
                     warns rather than refusing to start. (FIX would rewrite
                     the entity mapping at runtime to match the DB; not what
                     we want.) -->
                <prop key="hibernate.id.sequence.increment_size_mismatch_strategy">LOG</prop>
                <!-- Uncommenting the following line allows better logging of Hibernate errors for debugging purposes. Must be commented out for production use. -->
                <!-- prop key="hibernate.jdbc.batch_size">0</prop -->
            </props>
        </property>
