  <!-- A transaction manager for working with Hibernate SessionFactories -->
  <bean id="transactionManager" class="org.springframework.orm.hibernate5.HibernateTransactionManager">
    <property name="sessionFactory" ref="sessionFactory"/>
  </bean>
  
  <bean id="sharedTransactionTemplate" class="org.springframework.transaction.support.TransactionTemplate">
    <property name="transactionManager" ref="transactionManager"/>
  </bean>
  

  <!-- Phase B.5: HibernateTemplate bean retired. Spring 6's
       org.springframework.orm.hibernate5.HibernateTemplate references
       org.hibernate.criterion.Criterion which was deleted in Hibernate 6,
