<?xml version="1.0" encoding="UTF-8"?>
<!--
  Phase E.6 bulk-import — minimal CDISC ODM 1.3 sample for the smoke
  test referenced in docs/development/modernization/phase-e6-build-playbook-2026-06-05.md
  § 3.5 ("compose up → login → upload sample ODM XML → preview →
  commit → audit_log row visible").

  Two subjects, one event each, one CRF each, one item-data leaf each
  — enough to exercise the unmarshal + metadata-validation + preview
  projection paths without depending on a heavy study seed. Study OID
  matches the demo seed shipped with the compose stack (`S_DEMO`); if
  the operator's active study uses a different OID the metadata
  validator surfaces it as the documented 422 path.

  Mirrors the XSD root element name + namespace used by the legacy
  ImportCRFDataServlet — `org.openclinica.ns.odm.v130_api10.ODM` —
  and the standard `CRFDataPostImportContainer` shape that
  `ImportCRFDataService.validateStudyMetadata` consumes.
-->
<ODM xmlns="http://www.cdisc.org/ns/odm/v1.3"
     ODMVersion="1.3"
     FileType="Snapshot"
     FileOID="LCMUW_E6_BULK_IMPORT_SAMPLE"
     CreationDateTime="2026-06-06T00:00:00Z">
  <ClinicalData StudyOID="S_DEMO" MetaDataVersionOID="v1.0">
    <SubjectData SubjectKey="M-001">
      <StudyEventData StudyEventOID="SE_BASELINE">
        <FormData FormOID="F_DEMOGRAPHICS">
          <ItemGroupData ItemGroupOID="IG_CORE" TransactionType="Insert">
            <ItemData ItemOID="I_YEAR_OF_BIRTH" Value="1962"/>
          </ItemGroupData>
        </FormData>
      </StudyEventData>
    </SubjectData>
    <SubjectData SubjectKey="M-002">
      <StudyEventData StudyEventOID="SE_BASELINE">
        <FormData FormOID="F_DEMOGRAPHICS">
          <ItemGroupData ItemGroupOID="IG_CORE" TransactionType="Insert">
            <ItemData ItemOID="I_YEAR_OF_BIRTH" Value="1971"/>
          </ItemGroupData>
        </FormData>
      </StudyEventData>
    </SubjectData>
  </ClinicalData>
</ODM>
