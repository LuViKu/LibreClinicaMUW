<?xml version='1.0' encoding='UTF-8'?>
<!--
  DBUnit fixture for AuditUserLoginDaoTest. Multiple rows with varied
  user_name + login_status_code values so findAll() and getCountWithFilter()
  can both exercise meaningful assertions. Negative IDs prevent collision
  with any rows app bootstrap might insert.

  login_status_code values come from LoginStatus enum:
    1 = SUCCESSFUL_LOGIN
    2 = FAILED_LOGIN
-->
<dataset>

 <audit_user_login id="-1" user_name="testUser"          login_status_code="1" version="0"/>
 <audit_user_login id="-2" user_name="testUser"          login_status_code="2" version="0"/>
 <audit_user_login id="-3" user_name="muw-fixture-two"   login_status_code="1" version="0"/>
 <audit_user_login id="-4" user_name="muw-fixture-three" login_status_code="2" version="0"/>

</dataset>
